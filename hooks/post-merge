#!/usr/bin/env bash
# GitNexus auto-reindex after merge
# Disable: export GITNEXUS_AUTO_REINDEX=0

[[ "${GITNEXUS_AUTO_REINDEX:-1}" == "0" ]] && exit 0

REINDEX_SCRIPT="${GITNEXUS_STABLE_OPS:-}/bin/gitnexus-auto-reindex.sh"
if [[ ! -x "$REINDEX_SCRIPT" ]]; then
  for candidate in \
    "$HOME/.local/share/gitnexus-stable-ops/bin/gitnexus-auto-reindex.sh" \
    "$HOME/gitnexus-stable-ops/bin/gitnexus-auto-reindex.sh"; do
    [[ -x "$candidate" ]] && REINDEX_SCRIPT="$candidate" && break
  done
fi

[[ ! -x "$REINDEX_SCRIPT" ]] && exit 0

REPO_PATH="$(git rev-parse --show-toplevel 2>/dev/null)" \
  nohup "$REINDEX_SCRIPT" >/dev/null 2>&1 &

# --- Agent Graph auto-reindex (Phase 4/5) ---
if [[ "${GITNEXUS_AGENT_REINDEX:-1}" != "0" ]]; then
  AGENT_REINDEX="${GITNEXUS_STABLE_OPS:-}/bin/gitnexus-agent-reindex.sh"
  if [[ ! -x "$AGENT_REINDEX" ]]; then
    for candidate in \
      "$HOME/.local/share/gitnexus-stable-ops/bin/gitnexus-agent-reindex.sh" \
      "$HOME/gitnexus-stable-ops/bin/gitnexus-agent-reindex.sh"; do
      [[ -x "$candidate" ]] && AGENT_REINDEX="$candidate" && break
    done
  fi
  if [[ -x "$AGENT_REINDEX" ]]; then
    REPO_PATH="$(git rev-parse --show-toplevel 2>/dev/null)" \
      nohup "$AGENT_REINDEX" >/dev/null 2>&1 &
  fi
fi
