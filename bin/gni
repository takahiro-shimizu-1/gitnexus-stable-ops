#!/usr/bin/env bash
set -euo pipefail

DEFAULT_REPO="${DEFAULT_REPO:-$(basename "$PWD")}"
LOCK_TIMEOUT=3
GITNEXUS_BIN="${GITNEXUS_BIN:-$HOME/.local/bin/gitnexus-stable}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

_log()  { echo -e "${GREEN}[gni]${NC} $*" >&2; }
_warn() { echo -e "${YELLOW}[gni]${NC} $*" >&2; }
_err()  { echo -e "${RED}[gni]${NC} $*" >&2; }
_gitnexus() { "$GITNEXUS_BIN" "$@"; }

_db_lock_path() {
  if [[ -f "$PWD/.gitnexus/lbug" ]]; then
    echo "$PWD/.gitnexus/lbug"
    return 0
  fi
  if [[ -e "$PWD/.gitnexus/kuzu" ]]; then
    echo "$PWD/.gitnexus/kuzu"
    return 0
  fi
  return 1
}

_embedding_flag() {
  local meta_file="$PWD/.gitnexus/meta.json"
  [[ -f "$meta_file" ]] || return 0
  python3 - "$meta_file" <<'PY'
import json, sys
from pathlib import Path
meta_path = Path(sys.argv[1])
try:
    data = json.loads(meta_path.read_text())
except Exception:
    raise SystemExit(0)
if int(data.get("stats", {}).get("embeddings", 0) or 0) > 0:
    print("--embeddings")
PY
}

_ensure_no_lock() {
  local lock_holder="" db_path=""
  db_path=$(_db_lock_path || true)
  if [[ -n "$db_path" ]]; then
    if command -v fuser >/dev/null 2>&1; then
      lock_holder=$(fuser "$db_path" 2>/dev/null || true)
    elif command -v lsof >/dev/null 2>&1; then
      lock_holder=$(lsof "$db_path" 2>/dev/null | awk 'NR>1{print $2}' | head -1 || true)
    fi
  fi
  if [[ -n "$lock_holder" ]]; then
    _warn "DB lock detected: $lock_holder"
    sleep "$LOCK_TIMEOUT"
  fi
}

_detect_repo() {
  for arg in "$@"; do
    [[ "$arg" == "--repo" ]] && return 0
  done
  echo "--repo $DEFAULT_REPO"
}

_run_cypher() {
  local repo_flag="$1"
  shift
  local query="$1"
  local raw md
  raw=$(_gitnexus cypher $repo_flag "$query" 2>&1) || true
  [[ -n "$raw" ]] || { echo "  (結果なし)"; return; }
  md=$(echo "$raw" | python3 -c 'import sys,json
try:
 d=json.load(sys.stdin)
 print(d.get("markdown") or d.get("error") or "")
except Exception:
 print(sys.stdin.read())')
  [[ -n "$md" ]] || { echo "  (結果なし)"; return; }
  echo "$md"
}

_escape_cypher() {
  # Escape single quotes for Cypher string literals
  printf '%s' "${1//\'/\\\'}"
}

cmd_impact() {
  local target="$1"
  shift
  local repo_flag safe_target
  repo_flag=$(_detect_repo "$@")
  safe_target=$(_escape_cypher "$target")
  _log "impact fallback view for $target"
  echo -e "\n${CYAN}=== upstream ===${NC}\n"
  _run_cypher "$repo_flag" \
    "MATCH (a)-[r:CodeRelation]->(b) WHERE b.name = '$safe_target' AND r.type = 'CALLS' RETURN a.name AS caller, a.filePath AS file LIMIT 30"
  echo -e "\n${CYAN}=== downstream ===${NC}\n"
  _run_cypher "$repo_flag" \
    "MATCH (a)-[r:CodeRelation]->(b) WHERE a.name = '$safe_target' AND r.type = 'CALLS' RETURN b.name AS callee, b.filePath AS file LIMIT 30"
}

cmd_query()   { local repo_flag; repo_flag=$(_detect_repo "$@"); _gitnexus query "$repo_flag" "$@" 2>/dev/null; }
cmd_context() { local repo_flag; repo_flag=$(_detect_repo "$@"); _gitnexus context "$repo_flag" "$@" 2>/dev/null; }
cmd_cypher()  { local repo_flag; repo_flag=$(_detect_repo "$@"); _run_cypher "$repo_flag" "$@"; }
cmd_status()  { _gitnexus status 2>/dev/null; echo ""; _gitnexus list 2>/dev/null; }

cmd_reindex() {
  local analyze_args=(--force)
  local maybe_embeddings
  maybe_embeddings=$(_embedding_flag || true)
  [[ -n "$maybe_embeddings" ]] && analyze_args+=("$maybe_embeddings")
  _gitnexus analyze "${analyze_args[@]}" 2>&1
}

cmd_help() {
  cat <<'EOF'
gni — GitNexus Improved CLI Wrapper

Usage:
  gni impact <symbol>
  gni query <term>
  gni context <symbol>
  gni cypher "<query>"
  gni status
  gni reindex
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    impact|query|context|cypher|reindex) _ensure_no_lock ;;
  esac
  case "$cmd" in
    impact) cmd_impact "$@" ;;
    query) cmd_query "$@" ;;
    context) cmd_context "$@" ;;
    cypher) cmd_cypher "$@" ;;
    status) cmd_status ;;
    reindex) cmd_reindex ;;
    help|--help|-h) cmd_help ;;
    *) _gitnexus "$cmd" "$@" ;;
  esac
}

main "$@"
